<Window x:Class="_10._03._2026_slepa_mapa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slepá mapa" Height="500" Width="900">

    <Grid>

        <!-- mapa -->
        <Image Name="MapImage"
               Source="img/czechia.png"
               Stretch="Uniform"
               SizeChanged="MapImage_SizeChanged"/>

        <!-- body -->
        <Canvas Name="OverlayCanvas"/>

        <!-- horní panel -->
        <StackPanel VerticalAlignment="Top" Background="#AAFFFFFF">
            <TextBlock Name="TxtTarget" FontSize="20" Margin="10"/>
            <TextBlock Name="TxtScore" FontSize="16" Margin="10"/>
        </StackPanel>

    </Grid>
</Window>